{
  "name": "Haes",
  "type": "object",
  "properties": {
    "haesnummer": {
      "type": "string"
    },
    "haesgruppe_id": {
      "type": "string"
    },
    "bezeichnung": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Aktiv",
        "Verliehen",
        "Verkauft",
        "Frei",
        "Stillgelegt"
      ],
      "default": "Frei"
    },
    "aktueller_besitzer_id": {
      "type": "string"
    },
    "notizen": {
      "type": "string"
    },
    "bild_url": {
      "type": "string"
    },
    "vereinseigentum": {
      "type": "boolean",
      "default": false,
      "description": "Gibt an, ob das H\u00e4s dem Verein geh\u00f6rt"
    },
    "privat_eigentuemer_id": {
      "type": "string",
      "description": "Mitglied, dem das H\u00e4s privat geh\u00f6rt (nur wenn kein Vereinseigentum)"
    }
  },
  "required": [
    "haesnummer"
  ]
}